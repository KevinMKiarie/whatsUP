# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://whatsup:whatsup@localhost:5432/whatsup"

# ── AI ────────────────────────────────────────────────────────────────────────
# Local Ollama (default). Swap baseURL + apiKey to use Claude API later.
OLLAMA_URL="http://localhost:11434/v1"
OLLAMA_MODEL="qwen2.5:14b"

# ── WhatsApp — Phase 1: Evolution API (dev/test) ─────────────────────────────
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_INSTANCE="my-salon"
EVOLUTION_API_KEY="your-evolution-api-key"

# ── WhatsApp — Phase 2: Meta Cloud API (production) ──────────────────────────
# META_ACCESS_TOKEN=""
# META_PHONE_NUMBER_ID=""
# META_VERIFY_TOKEN=""

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Better Auth (dashboard) ───────────────────────────────────────────────────
# Generate a secret: openssl rand -hex 32
BETTER_AUTH_SECRET="change-me-to-a-random-64-char-hex-string"
# Base URL of the Next.js app (used by Better Auth for redirects)
BETTER_AUTH_URL="http://localhost:3000"
# First admin user — run: pnpm --filter @whatsup/web create-admin
ADMIN_EMAIL="admin@glowstudio.co"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Admin"

# ── Web app (set at build time for Docker; localhost works for dev) ───────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
# Docker internal URL used by Next.js server-side fetch:
API_URL="http://api:3001/api"
